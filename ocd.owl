  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-fenoprofen-noun-1">
    <ns4:gloss xml:lang="en-us">(a nonsteroidal anti-inflammatory drug (trade name Nalfon) used in the treatment of arthritis and other painful inflammatory disorders)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-pheromone-noun-1">
    <ns4:gloss xml:lang="en-us">(a chemical substance secreted externally by some animals (especially insects) that influences the physiology or behavior of other animals of the same species)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#form_sexual_intrusive_thought_unwanted_sexual_thoughts_1">
