  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-addle-head-noun-1">
    <ns4:gloss xml:lang="en-us">(a person with confused ideas; incapable of serious thought)</ns4:gloss>
