    <ontolex:reference rdf:resource="https://w3id.org/ocd#Environmental_Factor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-B-complex_vitamin-noun-1">
    <ns4:gloss xml:lang="en-us">(originally thought to be a single vitamin but now separated into several B vitamins)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_011995">
    <obo:IAO_0000115 xml:lang="en">A variation of "rest in peace" used mainly among Black and LGBTQIA+ community members as an expression to mourn, remember or celebrate a deceased person, especially someone who is thought to have struggled against systemic prejudice such as racism, homophobia or transphobia, or suffered because of it. It has been used to eulogize victims of hate crimes while protesting the social inequality and institutionalised discrimination that may have led to their deaths.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-indecent-adjectivesatellite-1">
    <ns4:gloss xml:lang="en-us">(not in keeping with accepted standards of what is right or proper in polite society; "was buried with indecent haste"; "indecorous behavior"; "language unbecoming to a lady"; "unseemly to use profanity"; "moved to curb their untoward ribaldry")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-exteriorize-verb-2">
    <ns4:gloss xml:lang="en-us">(make external or objective, or give reality to; "language externalizes our thoughts")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-surely-adverb-1">
    <ns4:gloss xml:lang="en-us">(definitely or positively (`sure' is sometimes used informally for `surely'); "the results are surely encouraging"; "she certainly is a hard worker"; "it's going to be a good day for sure"; "they are coming, for certain"; "they thought he had been killed sure enough"; "he'll win sure as shooting"; "they sure smell good"; "sure he'll come")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0020023">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
