  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-tax_benefit-noun-1">
    <ns4:gloss xml:lang="en-us">(a tax deduction that is granted in order to encourage a particular type of commercial activity)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-slow_virus-noun-1">
    <ns4:gloss xml:lang="en-us">(a virus that remains dormant in the body for a long time before symptoms appear; "kuru is caused by a slow virus")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-busy-adjectivesatellite-4">
    <ns4:gloss xml:lang="en-us">(crowdedwith or characterized by much activity; "a very busy week"; "a busy life"; "a busy street"; "a busy seaport")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-driven-adjectivesatellite-2">
    <ns4:gloss xml:lang="en-us">(urged or forced to action through moral pressure; "felt impelled to take a stand against the issue")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-Watson-noun-2">
    <ns4:gloss xml:lang="en-us">(United States psychologist considered the founder of behavioristic psychology (1878-1958))</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-listlessness-noun-2">
    <ns4:gloss xml:lang="en-us">(inactivity resulting from torpidity and lack of vigor or energy)</ns4:gloss>
