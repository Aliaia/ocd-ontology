  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-breathless-adjective-1">
    <ns4:gloss xml:lang="en-us">(not breathing or able to breathe except with difficulty; "breathless at thought of what I had done"; "breathless from running"; "followed the match with breathless interest")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_trigger_induction_3">
