    <ns4:gloss xml:lang="en-us">(the activity of operating something (a machine or business etc.); "her smooth operation of the vehicle gave us a surprisingly comfortable ride")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/MF_0000083">
    <obo:IAO_0000115>A mental process that evokes the representation of the sensory characteristics of objects or events when these are not immediately present to the senses.</obo:IAO_0000115>
