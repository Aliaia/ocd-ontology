  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-itch-verb-3">
    <ns4:gloss xml:lang="en-us">(have a strong desire or urge to do something; "She is itching to start the project"; "He is spoiling for a fight")</ns4:gloss>
