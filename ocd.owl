  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_008746">
    <obo:IAO_0000115 xml:lang="en">A slang term referred to the moment a person uncovers or learns about a transgender person's status as transgender, particularly if the transgender person has not yet undergone genital gender confirmation surgery.</obo:IAO_0000115>
