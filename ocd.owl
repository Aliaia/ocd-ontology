  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-alopecia-noun-1">
    <ns4:gloss xml:lang="en-us">(loss of hair (especially on the head) or loss of wool or feathers; in humans it can result from heredity or hormonal imbalance or certain diseases or drugs and treatments (chemotherapy for cancer))</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-suckling_reflex-noun-1">
    <ns4:gloss xml:lang="en-us">(reflex behavior in newborn mammals; includes finding and grasping the nipple in the mouth and sucking on it and swallowing the milk)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-drumhead_court-martial-noun-1">
    <ns4:gloss xml:lang="en-us">(a military court convened to hear urgent charges of offences committed in action)</ns4:gloss>
