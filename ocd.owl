  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-bleed-verb-2">
    <ns4:gloss xml:lang="en-us">(draw blood; "In the old days, doctors routinely bled patients as part of the treatment")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-mature-verb-2">
    <ns4:gloss xml:lang="en-us">(develop and work out fully in one's mind; "I need to mature my thoughts")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-graphic-adjectivesatellite-2">
    <ns4:gloss xml:lang="en-us">(describing nudity or sexual activity in graphic detail; "graphic sexual scenes")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-hostile-adjectivesatellite-6">
    <ns4:gloss xml:lang="en-us">(marked by features that oppose constructive treatment or development; "not able to accomplish much in such a hostile environment")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#form_severity_control_level_rigourousness_4">
    <rdf:type rdf:resource="http://www.w3.org/ns/lemon/ontolex#Form"/>
