  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-vagary-noun-1">
    <ns4:gloss xml:lang="en-us">(an unexpected and inexplicable change in something (in a situation or a person's behavior, etc.); "the vagaries of the weather"; "his wealth fluctuates with the vagaries of the stock market"; "he has dealt with human vagaries for many years")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_assessment_criterion_criterion_0">
