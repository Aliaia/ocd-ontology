    <rdf:type rdf:resource="http://www.w3.org/2006/03/wn/wn20/schema/Collocation"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-tardive-adjectivesatellite-1">
    <ns4:gloss xml:lang="en-us">(late-occurring (especially with reference to symptoms of a disease); "tardive dyskinesia")</ns4:gloss>
  </rdf:Description>
