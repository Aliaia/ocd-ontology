  <rdf:Description rdf:about="https://w3id.org/ocd#Symmetry_Obsession">
    <rdfs:comment>Symmetry obsessions are characterized by the need for things to be perfect, exact or “just right,” symmetrical, or correctly aligned, and related compulsions include ordering and arranging, evening up or aligning things, and touching or tapping. This definition is taken from ``Lochner, Christine, et al. "Symmetry symptoms in obsessive-compulsive disorder: clinical and genetic correlates." Brazilian Journal of Psychiatry 38 (2015): 17-23.''</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/ocd#Obsession"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
