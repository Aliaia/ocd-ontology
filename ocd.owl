  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-play-noun-14">
    <ns4:gloss xml:lang="en-us">(gay or light-hearted recreational activity for diversion or amusement; "it was all done in play"; "their frolic in the surf threatened to become ugly")</ns4:gloss>
  </rdf:Description>
