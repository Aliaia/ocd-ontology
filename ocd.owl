  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-paranoid_schizophrenia-noun-1">
    <ns4:gloss xml:lang="en-us">(a form of schizophrenia characterized by delusions (of persecution or grandeur or jealousy); symptoms may include anger and anxiety and aloofness and doubts about gender identity; unlike other types of schizophrenia the patients are usually presentable and (if delusions are not acted on) may function in an apparently normal manner)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-hair-trigger-adjectivesatellite-1">
