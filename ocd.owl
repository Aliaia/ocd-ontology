  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-market-noun-1">
    <ns4:hyponymOf rdf:resource="http://www.w3.org/2006/03/wn/wn20/instances/synset-activity-noun-1"/>
    <ns4:gloss xml:lang="en-us">(the world of commercial activity where goods and services are bought and sold; "without competition there would be no market"; "they were driven from the marketplace")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-contributory_negligence-noun-1">
    <ns4:gloss xml:lang="en-us">((law) behavior by the plaintiff that contributes to the harm resulting from the defendant's negligence; in common law any degree of contributory negligence would bar the plaintiff from collecting damages)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-East_Turkistan_Islamic_Movement-noun-1">
