    <ns4:gloss xml:lang="en-us">(large brightly marked tropical insect with a process like a snout that was formerly thought to emit light)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-chlordiazepoxide-noun-1">
    <ns4:gloss xml:lang="en-us">(a tranquilizer (trade names Librium and Libritabs) used in the treatment of alcoholism)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-boorish-adjectivesatellite-1">
    <ns4:gloss xml:lang="en-us">(ill-mannered and coarse and contemptible in behavior or appearance; "was boorish and insensitive"; "the loutish manners of a bully"; "her stupid oafish husband"; "aristocratic contempt for the swinish multitude")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-envisioned-adjectivesatellite-1">
    <ns4:gloss xml:lang="en-us">(seen in the mind as a mental image; "the glory of his envisioned future"; "the snow-covered Alps pictured in her imagination"; "the visualized scene lacked the ugly details of real life")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-epidural_anesthesia-noun-1">
    <ns4:gloss xml:lang="en-us">(regional anesthesia resulting from injection of an anesthetic into the epidural space of the spinal cord; sensation is lost in the abdominal and genital and pelvic areas; used in childbirth and gynecological surgery)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#form_obsessive_compulsive_related_disorder_obsessive_compulsive_spectrum_disorder_2">
