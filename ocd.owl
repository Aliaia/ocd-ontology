    <ns4:gloss xml:lang="en-us">(the branch of medicine concerned with the study and treatment of tumors)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_009227">
    <rdfs:comment xml:lang="en">ROGD is not recognized by any major professional association and is not listed in the International Classification of Diseases, Tenth Edition (ICD-10) or the Diagnostic and Statistical Manual of Mental Disorders, Fifth Edition (DSM-5). WPATH regards the term as problematic, being used to instill fear in parents whose children may or may not be transgender, and urges entities to avoid using ROGD for the time being.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-vehicle-noun-1">
    <ns4:gloss xml:lang="en-us">(a conveyance that transports people or objects)</ns4:gloss>
