  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-off-site-adjective-1">
    <ns4:gloss xml:lang="en-us">(taking place or located away from the site; "an off-site waste treatment operation")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-medicine-noun-2">
    <ns4:gloss xml:lang="en-us">((medicine) something that treats or prevents or alleviates the symptoms of disease)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-bottle_collection-noun-2">
    <ns4:gloss xml:lang="en-us">(the activity of collecting bottles; "bottle collection is a hobby of hers")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalentry_contamination_obsession_compulsion_1">
    <rdf:type rdf:resource="http://www.w3.org/ns/lemon/ontolex#LexicalEntry"/>
    <ontolex:canonicalForm rdf:resource="https://w3id.org/ocd/lexicon#form_contamination_obsession_compulsion_1"/>
    <ontolex:sense rdf:resource="https://w3id.org/ocd/lexicon#lexicalsense_contamination_obsession_compulsion_1"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-dispiritedly-adverb-1">
    <ns4:gloss xml:lang="en-us">(in a dispirited manner without hope; "the first Mozartian opera to be subjected to this curious treatment ran dispiritedly for five performances")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_doubt_obsession_fixation_5">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Doubt_Obsession"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-stimulating-adjective-1">
    <ns4:gloss xml:lang="en-us">(rousing or quickening activity or the senses; "a stimulating discussion")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000019">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-reconsideration-noun-2">
    <ns4:containsWordSense rdf:resource="http://www.w3.org/2006/03/wn/wn20/instances/wordsense-afterthought-noun-1"/>
    <ns4:containsWordSense rdf:resource="http://www.w3.org/2006/03/wn/wn20/instances/wordsense-second_thought-noun-1"/>
    <ns4:gloss xml:lang="en-us">(thinking again about a choice previously made; "he had second thoughts about his purchase")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/word-trigger_off">
