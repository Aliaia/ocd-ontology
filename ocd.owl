  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-inappropriate-adjectivesatellite-2">
    <ns4:gloss xml:lang="en-us">(not conforming with accepted standards of propriety or taste; undesirable; "incorrect behavior"; "she was seen in all the wrong places"; "He thought it was wrong for her to go out to work")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-habitude-noun-1">
    <ns4:gloss xml:lang="en-us">(habitual mode of behavior)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-conceptualism-noun-1">
    <ns4:gloss xml:lang="en-us">(the doctrine that the application of a general term to various objects indicates the existence of a mental entity that mediates the application)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_somatic_intrusive_image_bodily_0">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Somatic_Intrusive_Image"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-miss-verb-3">
    <ns4:gloss xml:lang="en-us">(fail to attend an event or activity; "I missed the concert"; "He missed school for a week")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_contamination_obsession_contaminant_0">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Contamination_Obsession"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-object-verb-2">
    <ns4:gloss xml:lang="en-us">(be averse to or express disapproval of; "My wife objects to modern furniture")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-hoist-noun-1">
    <ns4:gloss xml:lang="en-us">(lifting device for raising heavy or cumbersome objects)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-impossible-adjectivesatellite-3">
    <ns4:gloss xml:lang="en-us">(used of persons or their behavior; "impossible behavior"; "insufferable insolence")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-cephalosporin-noun-1">
    <ns4:gloss xml:lang="en-us">(one of several broad spectrum antibiotic substances obtained from fungi and related to penicillin (trade names Mefoxin); addition of side chains has produced semisynthetic antibiotics with greater antibacterial activity)</ns4:gloss>
  </rdf:Description>
