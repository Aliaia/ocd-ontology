    <ns4:gloss xml:lang="en-us">(using a computerized radiographic technique to examine the metabolic activity in various tissues (especially in the brain))</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-tongs-noun-1">
    <ns4:gloss xml:lang="en-us">(any of various devices for taking hold of objects; usually have two hinged legs with handles above and pointed hooks below)</ns4:gloss>
