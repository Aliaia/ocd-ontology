  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_006262">
    <obo:IAO_0000115 xml:lang="en">Clinic providing services for transwomen, including facial feminization surgery (FFS), body feminization surgeries (such as breast augmentation and hip augmentation), electrolysis hair removal, and voice feminization speech therapy. Located in Antwerp, Belgium. Operated by Dr. Bart van de Ven and Dr. Ellen Defrancq, among others.</obo:IAO_0000115>
