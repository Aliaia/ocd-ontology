  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000201">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-narrow-mindedness-noun-1">
    <ns4:gloss xml:lang="en-us">(an inclination to criticize opposing opinions or shocking behavior)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-socialization-noun-3">
    <ns4:gloss xml:lang="en-us">(the adoption of the behavior patterns of the surrounding culture; "the socialization of children to the norms of their culture")</ns4:gloss>
  </rdf:Description>
