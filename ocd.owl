  <rdf:Description rdf:about="https://w3id.org/ocd#hasTrigger">
    <rdfs:domain rdf:nodeID="N8ae1869bf87946c5a8a261c2de1612c5"/>
    <rdfs:range rdf:resource="https://w3id.org/ocd#Objects"/>
    <rdfs:comment>The object property hasTrigger specifies the relationship between a behavior, activity, intrusive thought, or urge and the object, room/location, or event that triggers it. This property is used to indicate what causes or initiates the behavior, activity, intrusive thought, or urge.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
