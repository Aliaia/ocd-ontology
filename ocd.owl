  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-pseudoscience-noun-1">
    <ns4:gloss xml:lang="en-us">(an activity resembling science but based on fallacious assumptions)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-television-noun-1">
    <ns4:gloss xml:lang="en-us">(broadcasting visual images of stationary or moving objects; "she is a star of screen and video"; "Television is a medium because it is neither rare nor well done" - Ernie Kovacs)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000657">
