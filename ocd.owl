  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_001805">
    <dc1:replaces xml:lang="en">behavioral abnormality</dc1:replaces>
    <dc1:replaces xml:lang="en">dysfunctional behavior</dc1:replaces>
    <rdfs:label xml:lang="en">abnormal behavior</rdfs:label>
    <schema:alternateName xml:lang="en">abnormal behaviors</schema:alternateName>
    <obo:IAO_0000115 xml:lang="en">Note that abnormal behavior is usually a sign or symptom indicative of one of many psychiatric disorders, making it ostensibly different than behavior deemed unusual.</obo:IAO_0000115>
