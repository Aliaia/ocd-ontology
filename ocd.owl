  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-Cox-2_inhibitor-noun-1">
    <ns4:gloss xml:lang="en-us">(an anti-inflammatory drug that blocks Cox-2 activity without impeding the activity of Cox-1; "Cox-2 inhibitors reduce the symptoms of arthritis without endangering the stomach and kidneys")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000763">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
