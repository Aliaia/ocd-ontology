  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-communication-noun-1">
    <ns4:gloss xml:lang="en-us">(the activity of communicating; the activity of conveying information; "they could not act without official communication from Moscow")</ns4:gloss>
