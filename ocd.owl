  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-rail_technology-noun-1">
    <ns4:gloss xml:lang="en-us">(the activity of designing and constructing and operating railroads)</ns4:gloss>
  </rdf:Description>
