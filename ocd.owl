  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-book-noun-2">
    <ns4:gloss xml:lang="en-us">(physical objects consisting of a number of pages bound together; "he used a large book as a doorstop")</ns4:gloss>
  </rdf:Description>
