  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-dressing-noun-6">
    <ns4:gloss xml:lang="en-us">(the activity of getting dressed; putting on clothes)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-male_chauvinism-noun-1">
    <ns4:gloss xml:lang="en-us">(activity indicative of belief in the superiority of men over women)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalentry_aggressive_intrusive_urge_aggressive_impulses_2">
