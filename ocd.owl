  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-break_in-verb-3">
    <ns4:gloss xml:lang="en-us">(start in a certain activity, enterprise, or role)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0044511">
    <obo:IAO_0000115>A process that begins with venom being forced into an organism by the bite or sting of another organism, and ends with the resultant modulation of receptor activity in of the bitten organism.</obo:IAO_0000115>
    <rdfs:label>envenomation resulting in modulation of receptor activity in other organism</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/word-behavioristic">
