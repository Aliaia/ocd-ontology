  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-professionalization-noun-1">
    <ns4:gloss xml:lang="en-us">(the social process whereby people come to engage in an activity for pay or as a means of livelihood; "the professionalization of American sports"; "the professionalization of warfare")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_symptoms_clinical_features_4">
