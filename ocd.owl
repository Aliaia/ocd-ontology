    <rdf:type rdf:resource="http://www.w3.org/ns/lemon/ontolex#Form"/>
    <ontolex:writtenRep>accumulate</ontolex:writtenRep>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-anestrus-noun-1">
    <ns4:gloss xml:lang="en-us">(applies to nonhuman mammals: a state or interval of sexual inactivity between two periods of estrus)</ns4:gloss>
  </rdf:Description>
