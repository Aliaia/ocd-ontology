  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-disinfection-noun-1">
    <ns4:gloss xml:lang="en-us">(treatment to destroy harmful microorganisms)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/NCIT_C38025">
    <obo:IAO_0000115 xml:lang="en">Speech is the expression of thoughts and feelings by sound.</obo:IAO_0000115>
  </rdf:Description>
