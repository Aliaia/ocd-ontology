  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-animatism-noun-1">
    <ns4:gloss xml:lang="en-us">(the attribution of consciousness and personality to natural phenomena such as thunderstorms and earthquakes and to objects such as plants and stones)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-Lorenz-noun-1">
    <ns4:gloss xml:lang="en-us">(Austrian zoologist who studied the behavior of birds and emphasized the importance of innate as opposed to learned behaviors (1903-1989))</ns4:gloss>
  </rdf:Description>
