    <ontolex:reference rdf:resource="https://w3id.org/ocd#Urge"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000134">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
