    <ns4:gloss xml:lang="en-us">(not brought to a conclusion; subject to further thought; "an open question"; "our position on this bill is still undecided"; "our lawsuit is still undetermined")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-cosmetic-adjectivesatellite-2">
