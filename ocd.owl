    <obo:IAO_0000115 xml:lang="en">Used to refer to cross-dressing full-time and living as another gender role, especially for transgender men and women. Previously common as a preparatory step prior to gender confirmation surgery.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-paralytic-adjective-1">
