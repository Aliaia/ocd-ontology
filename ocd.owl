  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-constraint-noun-3">
    <ns4:gloss xml:lang="en-us">(the act of constraining; the threat or use of force to control the thoughts or behavior of others)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-cauterize-verb-1">
    <ns4:gloss xml:lang="en-us">(burn, sear, or freeze (tissue) using a hot iron or electric current or a caustic agent; "The surgeon cauterized the wart")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000578">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-tolerantly-adverb-1">
    <ns4:gloss xml:lang="en-us">(in a tolerant manner; "he reacts rather tolerantly toward his son's juvenile behavior")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-automatic_firearm-noun-1">
    <ns4:gloss xml:lang="en-us">(a firearm that reloads itself and keeps firing until the trigger is released)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-unreserved-adjective-2">
    <ns4:gloss xml:lang="en-us">(not cautious or reticent; "unreserved behavior")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_severity_distress_level_rigor_2">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Severity_Distress_Level"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-tactful-adjectivesatellite-2">
    <ns4:gloss xml:lang="en-us">(showing skill and sensitivity in dealing with people; "by diplomatic conduct he avoided antagonizing anyone"; "a tactful way of correcting someone"; "the agency got the kid-glove treatment on Capitol Hill")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-forward-adjective-3">
    <ns4:gloss xml:lang="en-us">(used of temperament or behavior; lacking restraint or modesty; "a forward child badly in need of discipline")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_sexual_intrusive_thought_inappropriate_sexual_thoughts_3">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Sexual_Intrusive_Thought"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_006929">
    <obo:IAO_0000115 xml:lang="en">A historically common medical diagnosis for women, which was described as exhibiting a wide array of symptoms, including anxiety, shortness of breath, fainting, nervousness, sexual desire, insomnia, fluid retention, heaviness in the abdomen, irritability, loss of appetite for food or sex, (paradoxically) sexually forward behaviour, and a "tendency to cause trouble for others". It is no longer recognized by medical authorities as a medical disorder.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/DOID_150">
    <obo:IAO_0000115>A disease that involves a psychological or behavioral pattern generally associated with subjective distress or disability that occurs in an individual, and which are not a part of normal development or culture.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-receptiveness-noun-1">
    <ns4:gloss xml:lang="en-us">(willingness or readiness to receive (especially impressions or ideas); "he was testing the government's receptiveness to reform"; "this receptiveness is the key feature is oestral behavior, enabling natural mating to occur"; "their receptivity to the proposal")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-feminine-noun-1">
    <ns4:gloss xml:lang="en-us">(a gender that refers chiefly (but not exclusively) to females or to objects classified as female)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-impulsiveness-noun-1">
    <ns4:hyponymOf rdf:resource="http://www.w3.org/2006/03/wn/wn20/instances/synset-unthoughtfulness-noun-1"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-hurt-adjectivesatellite-2">
    <ns4:gloss xml:lang="en-us">(used of inanimate objects or their value)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/DOID_0080832">
    <obo:IAO_0000115>A cognitive disorder that is characterized by objective impairment in cognition with minimal impairment of their capacity to undertake the instrumental activities of daily living.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-call-verb-9">
    <ns4:gloss xml:lang="en-us">(order, summon, or request for a specific duty or activity, work, role; "He was already called 4 times for jury duty"; "They called him to active military duty")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-circadian_rhythm-noun-1">
    <ns4:gloss xml:lang="en-us">(a daily cycle of activity observed in many living organisms)</ns4:gloss>
  </rdf:Description>
