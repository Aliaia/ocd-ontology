    <ns4:gloss xml:lang="en-us">(a long-lasting liquid antiseptic; used by surgeons to wash their hands before performing surgery)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-variation-noun-2">
    <ns4:gloss xml:lang="en-us">(an activity that varies from a norm or standard; "any variation in his routine was immediately reported")</ns4:gloss>
