  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-unrefined-adjective-2">
    <ns4:gloss xml:lang="en-us">(used of persons and their behavior; not refined; uncouth; "how can a refined girl be drawn to such an unrefined man?")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000340">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
