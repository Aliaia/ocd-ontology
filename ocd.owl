  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-enzymology-noun-1">
    <ns4:gloss xml:lang="en-us">(the branch of biochemistry dealing with the chemical nature and biological activity of enzymes)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/NCIT_C19988">
    <obo:IAO_0000115 xml:lang="en">A biologic function, activity, or process involving either specialized organ functions, individual organs, organ systems, body parts, or whole organisms.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-schizophrenia-noun-1">
    <ns4:gloss xml:lang="en-us">(any of several psychotic disorders characterized by distortions of reality and disturbances of thought and language and withdrawal from social contact)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000296">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#propertylexicalsense_hastreatment_handled_via_3">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#hasTreatment"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-unbuttoned-adjectivesatellite-2">
    <ns4:gloss xml:lang="en-us">(not under constraint in action or expression; "this unbuttoned and disrespectful age"- Curtis Bok; "unlaced behavior in the neighborhood pub")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-confused-adjectivesatellite-2">
    <ns4:gloss xml:lang="en-us">(lacking orderly continuity; "a confused set of instructions"; "a confused dream about the end of the world"; "disconnected fragments of a story"; "scattered thoughts")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-rousing-adjectivesatellite-2">
    <ns4:gloss xml:lang="en-us">(rousing to activity or heightened action as by spurring or goading; "tossed a rousing political comment into the conversation")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_mental_counting_reckoning_3">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Mental_Counting"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-exposure_therapy-noun-1">
    <ns4:gloss xml:lang="en-us">(a form of behavior therapy in which a survivor confronts feelings or phobias or anxieties about a traumatic event and relives it in the therapy situation)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-cutaneous_anthrax-noun-1">
    <ns4:gloss xml:lang="en-us">(a form of anthrax infection that begins as papule that becomes a vesicle and breaks with a discharge of toxins; symptoms of septicemia are severe with vomiting and high fever and profuse sweating; the infection is often fatal)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-modernization-noun-1">
    <ns4:gloss xml:lang="en-us">(making modern in appearance or behavior; "the modernization of Nigeria will be a long process")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-unashamed-adjective-1">
    <ns4:gloss xml:lang="en-us">(used of persons or their behavior; feeling no shame)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_obsessive_compulsive_related_disorder_ocrd_0">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Obsessive_Compulsive_Related_Disorder"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-old_growth-noun-1">
    <ns4:gloss xml:lang="en-us">(forest or woodland having a mature or overly mature ecosystem more or less uninfluenced by human activity)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N47a16d6d80ff414696d4d6a5d862296a">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
