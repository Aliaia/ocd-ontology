  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-inhibition-noun-1">
    <ns4:gloss xml:lang="en-us">((psychology) the conscious exclusion of unacceptable thoughts or desires)</ns4:gloss>
