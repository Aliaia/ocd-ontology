  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_007251">
    <obo:IAO_0000115 xml:lang="en">A term used to describe lesbian or bisexual women or color who express traditionally masculine behavior or traits; alternatively, a lesbian who has a stereotypically "hip-hop" or "gangster" look. This term has also been used to describe women considered "disagreeable", i.e. describing feminist activists, any woman who disagrees with a man, women who pursue a career, etc.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-extended-adjectivesatellite-3">
    <ns4:gloss xml:lang="en-us">(great in range or scope; "an extended vocabulary"; "surgeons with extended experience"; "extensive examples of picture writing"; "suffered extensive damage"; "a wide selection")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-loss-noun-4">
    <ns4:gloss xml:lang="en-us">(gradual decline in amount or activity; "weight loss"; "a serious loss of business")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0019158">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
