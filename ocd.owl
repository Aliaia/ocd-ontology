  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-deep_freeze-noun-1">
    <ns4:gloss xml:lang="en-us">(temporary inactivity or suspension; "the legislation has now been revived after ten years in the deep freeze")</ns4:gloss>
