  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_010229">
    <obo:IAO_0000115 xml:lang="en">Any of various behaviors in which one has a tendency to do harm to oneself, either as a direct or indirect result of their actions; frequently marked by impulse, but also includes chronic, injurious behaviors.</obo:IAO_0000115>
    <ns3:hasExactSynonym xml:lang="en">self destructive behavior</ns3:hasExactSynonym>
    <ns3:hasDbXref rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Self-destructive_behavior</ns3:hasDbXref>
