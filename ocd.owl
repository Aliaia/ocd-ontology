  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-prolong-verb-2">
    <ns4:gloss xml:lang="en-us">(lengthen or extend in duration or space; "We sustained the diplomatic negociations as long as possible"; "prolong the treatment of the patient"; "keep up the good work")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-paramedic-noun-1">
    <ns4:gloss xml:lang="en-us">(a person trained to assist medical professionals and to give emergency medical treatment)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-untreated-adjective-1">
    <ns4:gloss xml:lang="en-us">(not given medical care or treatment; "an untreated disease"; "the untreated wounded lay on makeshift cots")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-carry-verb-21">
    <ns4:gloss xml:lang="en-us">(have or possess something abstract; "I carry her image in my mind's eye"; "I will carry the secret to my grave"; "I carry these thoughts in the back of my head"; "I carry a lot of life insurance")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-regeneration-noun-3">
    <ns4:gloss xml:lang="en-us">(the activity of spiritual or physical renewal)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000867">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000411">
    <obo:IAO_0000115 xml:lang="en">Hate is a deep and emotional extreme dislike, directed against a certain object or class of objects.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-surgical_spirit-noun-1">
    <ns4:gloss xml:lang="en-us">(methylated spirit used in the practice of medicine (especially for cleansing the skin before injections or before surgery))</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-delineation-noun-2">
    <ns4:gloss xml:lang="en-us">(a drawing of the outlines of forms or objects)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-intend-verb-1">
    <ns4:gloss xml:lang="en-us">(have in mind as a purpose; "I mean no harm"; "I only meant to help you"; "She didn't think to harm me"; "We thought to return early that night")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-detail-noun-3">
    <ns4:gloss xml:lang="en-us">(extended treatment of particulars; "the essay contained too much detail")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-curiously_enough-adverb-1">
    <ns4:gloss xml:lang="en-us">(curious (or funny or interesting or odd or strange) though it may seem; "curiously enough, he didn't recognize his old friend"; "interestingly enough, America is now dependent on Africa for a large part of its oil"; "funnily enough, the ones I thought so ugly were the ones that sold out first"; "oddly enough, he hasn't mentioned it")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-demeclocycline_hydrochloride-noun-1">
    <ns4:gloss xml:lang="en-us">(tetracycline antibacterial (trade name Declomycin) effective in the treatment of some bacterial and rickettsial and other infections)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-reign_of_terror-noun-1">
    <ns4:gloss xml:lang="en-us">(any period of brutal suppression thought to resemble the Reign of Terror in France)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-careful-adjective-1">
    <ns4:gloss xml:lang="en-us">(exercising caution or showing care or attention; "they were careful when crossing the busy street"; "be careful to keep her shoes clean"; "did very careful research"; "careful art restorers"; "careful of the rights of others"; "careful about one's behavior")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-sanatorium-noun-1">
    <ns4:gloss xml:lang="en-us">(a hospital for recuperation or for the treatment of chronic diseases)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000114">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-permissiveness-noun-1">
    <ns4:gloss xml:lang="en-us">(a disposition to allow freedom of choice and behavior)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000534">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-inward-adjective-1">
    <ns4:gloss xml:lang="en-us">(relating to or existing in the mind or thoughts; "a concern with inward reflections")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/MFOEM_000029">
    <obo:IAO_0000115>A negative emotion in response to a stressful elicitor. May be acute or chronic.  Associated with health implications, such as impaired resistance to infectious diseases. [Source: OCEAS]</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000370">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-play_out-verb-3">
    <ns4:gloss xml:lang="en-us">(play to a finish; "We have got to play this game out, even thought it is clear that we have last")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000251">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
