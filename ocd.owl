  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-dormant_account-noun-1">
    <ns4:gloss xml:lang="en-us">(a savings account showing no activity (other than posting interest) for some specified period; "the dormant account reverted to the state under escheat laws")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-bespeak-verb-1">
    <ns4:gloss xml:lang="en-us">(be a signal for or a symptom of; "These symptoms indicate a serious illness"; "Her behavior points to a severe neurosis"; "The economic indicators signal that the euro is undervalued")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-Oldenberg-noun-1">
    <ns4:gloss xml:lang="en-us">(United States sculptor (born in Sweden); a leader of the pop art movement who was noted for giant sculptures of common objects (born in 1929))</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-acathexis-noun-1">
    <ns4:gloss xml:lang="en-us">((psychoanalysis) a lack of cathexis; a condition in which significant objects or memories arouse no emotion in an individual)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0002211">
    <obo:IAO_0000115>A behavioral response seeking to protect an organism from an a perceived external threat from an insect or insects to that organism.</obo:IAO_0000115>
    <rdfs:label>behavioral defense response to insect</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalentry_religious_intrusive_image_religious_0">
