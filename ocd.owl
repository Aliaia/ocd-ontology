  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-terrorist-adjectivesatellite-1">
    <ns4:gloss xml:lang="en-us">(characteristic of someone who employs terrorism (especially as a political weapon); "terrorist activity"; "terrorist state")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-precedential-adjectivesatellite-1">
    <ns4:gloss xml:lang="en-us">(having precedence (especially because of longer service); "precedential treatment for senior members of the firm")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_000470">
    <obo:IAO_0000115 xml:lang="en">Broadly, a transgender person. Sometimes narrowly used to refer to a transgender person who is living full-time using the gender expression which matches their gender identity without considering surgeries related to genitalia.</obo:IAO_0000115>
  </rdf:Description>
