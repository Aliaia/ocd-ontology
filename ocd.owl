  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-adience-noun-1">
    <ns4:gloss xml:lang="en-us">((psychology) an urge to accept or approach a situation or an object)</ns4:gloss>
    <ns4:hyponymOf rdf:resource="http://www.w3.org/2006/03/wn/wn20/instances/synset-urge-noun-1"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/DOID_9973">
    <obo:IAO_0000115> When an individual persists in use of alcohol or other drugs despite problems related to use of the substance, substance dependence may be diagnosed. Compulsive and repetitive use may result in tolerance to the effect of the drug and withdrawal symptoms when use is reduced or stopped. 

(DSM-IV, American Psychiatric Association, 2000)          </obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-surgically-adverb-1">
    <ns4:gloss xml:lang="en-us">(in a surgical manner; by means of surgery; "surgically removed")</ns4:gloss>
  </rdf:Description>
