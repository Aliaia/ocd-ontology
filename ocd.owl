  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_011430">
    <obo:IAO_0000115 xml:lang="en">A fringe conspiracy theory which claims that puberty blocking medications used by transgender youth are utilized in order to cause asexuality, for any of various reasons, usually anti-Semitic in nature (such as claiming that puberty blockers/asexuality is used as a form of reproductive control by Jewish people).</obo:IAO_0000115>
  </rdf:Description>
