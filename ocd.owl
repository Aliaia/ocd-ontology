  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-diestrus-noun-1">
    <ns4:gloss xml:lang="en-us">((of animals having several estrous cycles in one breeding season) a state or interval of sexual inactivity or quiescence between periods of activity)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-electrotherapist-noun-1">
    <ns4:gloss xml:lang="en-us">(someone who specializes in the treatment of disease by electricity)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-talk-verb-1">
    <ns4:gloss xml:lang="en-us">(exchange thoughts; talk with; "We often talk business"; "Actions talk louder than words")</ns4:gloss>
