  <rdf:Description rdf:about="https://w3id.org/ocd#hasTreatment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment>The object property hasTreatment specifies the relationship between Obsessive-Compulsive Disorder (OCD) and the treatments used to manage and treat the condition. This property is used to link instances of OCD with specific treatment methods, indicating the therapeutic approaches employed to address the disorder.</rdfs:comment>
    <rdfs:range rdf:resource="https://w3id.org/ocd#Treatment"/>
    <rdfs:domain rdf:resource="https://w3id.org/ocd#Obsessive_Compulsive_Disorder"/>
