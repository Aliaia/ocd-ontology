  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-traffic-noun-3">
    <ns4:gloss xml:lang="en-us">(the amount of activity over a communication system during a given period of time; "heavy traffic overloaded the trunk lines"; "traffic on the internet is lightest during the night")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-discrimination-noun-1">
    <ns4:gloss xml:lang="en-us">(unfair treatment of a person or group on the basis of prejudice)</ns4:gloss>
