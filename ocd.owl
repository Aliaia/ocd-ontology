  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-uncleared-adjective-1">
    <ns4:gloss xml:lang="en-us">(not cleared; not rid of objects or obstructions; "uncleared land"; "many cars were stuck in the snow on uncleared streets")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-agnosia-noun-1">
