  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_001263">
    <obo:IAO_0000115 xml:lang="en">An ill-defined psychiatric diagnosis present in DSM-III-R, DSM-IV, and DSM-IV-TR. It was renamed transvestic disorder in DSM-V. The diagnostic criteria given were (1) individuals must be sexually aroused by the act of cross-dressing, and (2) individuals must experience significant distress or impairment – socially or occupationally – because of their behavior. Often tied to Ray Blanchard's pseudoscientific autogynephilia theory.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-automatism-noun-1">
    <ns4:gloss xml:lang="en-us">(any reaction that occurs automatically without conscious thought or reflection (especially the undirected behavior seen in psychomotor epilepsy))</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-unmindfully-adverb-1">
    <ns4:gloss xml:lang="en-us">(in a careless and thoughtless manner)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-object-noun-1">
    <ns4:gloss xml:lang="en-us">(a tangible and visible entity; an entity that can cast a shadow; "it was full of rackets, balls and other objects")</ns4:gloss>
  </rdf:Description>
