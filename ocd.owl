    <ns4:gloss xml:lang="en-us">(a treatment for addiction to drugs or alcohol intended to remove the physiological effects of the addictive substances)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-Lister-noun-1">
