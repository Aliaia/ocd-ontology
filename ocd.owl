    <ns4:gloss xml:lang="en-us">(activity contributing directly to the output of an organization)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-occupation-noun-1">
