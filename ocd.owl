  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-latent_period-noun-2">
    <ns4:gloss xml:lang="en-us">(the time that elapses before the presence of a disease is manifested by symptoms)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-indecorous-adjective-1">
    <ns4:gloss xml:lang="en-us">(lacking propriety and good taste in manners and conduct; "indecorous behavior")</ns4:gloss>
  </rdf:Description>
