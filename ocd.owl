  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-liquid_diet-noun-1">
    <ns4:gloss xml:lang="en-us">(a diet of foods that can be served in liquid or strained form (plus custards or puddings); prescribed after certain kinds of surgery)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-medusa_s_head-noun-1">
