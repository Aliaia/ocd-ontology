    <ns4:gloss xml:lang="en-us">((used of sexual behavior) showing or appealing to bizarre or deviant tastes; "kinky sex"; "perverted practices")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-medical_science-noun-1">
    <ns4:gloss xml:lang="en-us">(the science of dealing with the maintenance of health and the prevention and treatment of disease)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-syncretism-noun-1">
