  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-powder_metallurgy-noun-1">
    <ns4:gloss xml:lang="en-us">(the metallurgy of powdered metals; how to produce solid metal objects from powdered metal by compaction and sintering)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-sphinx-noun-1">
    <ns4:gloss xml:lang="en-us">(an inscrutable person who keeps his thoughts and intentions secret)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_religious_obsession_spiritual_2">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Religious_Obsession"/>
