    <rdf:type rdf:resource="http://www.w3.org/ns/lemon/ontolex#Form"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-attempt-noun-1">
    <ns4:hyponymOf rdf:resource="http://www.w3.org/2006/03/wn/wn20/instances/synset-activity-noun-1"/>
    <ns4:gloss xml:lang="en-us">(earnest and conscientious activity intended to do or accomplish something; "made an effort to cover all the reading material"; "wished him luck in his endeavor"; "she gave it a good try")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalentry_religious_intrusive_image_intrusive_2">
