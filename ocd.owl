  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-consideration-noun-6">
    <ns4:gloss xml:lang="en-us">(a considerate and thoughtful act)</ns4:gloss>
    <ns4:containsWordSense rdf:resource="http://www.w3.org/2006/03/wn/wn20/instances/wordsense-thoughtfulness-noun-4"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-desultory-adjectivesatellite-1">
    <ns4:gloss xml:lang="en-us">(marked by lack of definite plan or regularity or purpose; jumping from one thing to another; "desultory thoughts"; "the desultory conversation characteristic of cocktail parties")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_gender_factor_sexuality_6">
