  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-sociobiologically-adverb-1">
    <ns4:gloss xml:lang="en-us">(with respect to sociobiology; "explain the behavior sociobiologically")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-bandwagon_effect-noun-1">
    <ns4:gloss xml:lang="en-us">(the phenomenon of a popular trend attracting even greater popularity; "in periods of high merger activity there is a bandwagon effect with more and more firms seeking to engage in takeover activity"; "polls are accused of creating a bandwagon effect to benefit their candidate")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0035640">
    <obo:IAO_0000115>The specific behavior of an organism in response to a novel environment or stimulus.</obo:IAO_0000115>
    <rdfs:label>exploration behavior</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-colonic-noun-1">
    <ns4:hyponymOf rdf:resource="http://www.w3.org/2006/03/wn/wn20/instances/synset-purge-noun-2"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-exploitation-noun-2">
    <ns4:hyponymOf rdf:resource="http://www.w3.org/2006/03/wn/wn20/instances/synset-mistreatment-noun-1"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_006923">
    <obo:IAO_0000115 xml:lang="en">Traditionally, a personality disorder characterized by persistent antisocial behavior, impaired empathy and remorse, and bold, disinhibited, and egotistical traits. It is sometimes considered synonymous with sociopathy. Different conceptions of psychopathy have been used throughout history that are only partly overlapping and may sometimes be contradictory.</obo:IAO_0000115>
  </rdf:Description>
