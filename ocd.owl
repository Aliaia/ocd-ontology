  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_006842">
    <obo:IAO_0000115 xml:lang="en">A term used to refer to either a romantic rivalry involving three people (a love triangle), sexual activity involving three persons simultaneously (a threesome), or a domestic arrangement with three people sharing sexual and romantic relations as a form of polyamory (known as a throuple, thruple, or triad).</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#form_mental_counting_number_7">
