  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_007587">
    <obo:IAO_0000115 xml:lang="en">A phrase used in BDSM activities, noting that any activity undertaken should be safe, that all participants should be of sound mind in order to consent to that activity, and that all participants do actively and mutually consent.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_genetic_factor_constituent_6">
