  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_aggressive_intrusive_urge_violent_urges_0">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Aggressive_Intrusive_Urge"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-Parks-noun-1">
    <ns4:gloss xml:lang="en-us">(United States civil rights leader who refused to give up her seat on a bus to a white man in Montgomery (Alabama) and so triggered the national civil rights movement (born in 1913))</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-up-adverb-1">
    <ns4:gloss xml:lang="en-us">(spatially or metaphorically from a lower to a higher position; "look up!"; "the music surged up"; "the fragments flew upwards"; "prices soared upwards"; "upwardly mobile")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#form_treatment_therapeutic_intervention_4">
    <rdf:type rdf:resource="http://www.w3.org/ns/lemon/ontolex#Form"/>
    <ontolex:writtenRep>therapeutic intervention</ontolex:writtenRep>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_contamination_obsession_obsession_5">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Contamination_Obsession"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-propellant-adjectivesatellite-1">
    <ns4:gloss xml:lang="en-us">(tending to or capable of propelling; "propellant fuel for submarines"; "the faster a jet plane goes the greater its propulsive efficiency"; "universities...the seats of propulsive thought")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-bristling_with_p_-adjectivesatellite-1">
    <ns4:gloss xml:lang="en-us">(covered thickly with objects thrusting upward as with bristles; "roofs bristling with antennas"; "housetops bristlng with chimneys"; "a riverbank bristling with factories")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000227">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-present-noun-1">
    <ns4:gloss xml:lang="en-us">(the period of time that is happening now; any continuous stretch of time including the moment of speech; "that is enough for the present"; "he lives in the present with no thought of tomorrow")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000230">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalentry_aggressive_obsession_harm_related_obsessions_4">
    <ontolex:canonicalForm rdf:resource="https://w3id.org/ocd/lexicon#form_aggressive_obsession_harm_related_obsessions_4"/>
    <rdf:type rdf:resource="http://www.w3.org/ns/lemon/ontolex#LexicalEntry"/>
    <ontolex:sense rdf:resource="https://w3id.org/ocd/lexicon#lexicalsense_aggressive_obsession_harm_related_obsessions_4"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0034609">
    <obo:IAO_0000115>Insertion of the male copulatory spicules into the hermaphrodite. Spicule insertion behavior initiates when the male cloaca contacts the vulva. During most mating encounters, the spicule tips will prod the vulva continuously until they partially penetrate, which then causes the protractors to contract completely so that the spicules extend through the vulva.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-communion-noun-2">
    <ns4:gloss xml:lang="en-us">(sharing thoughts and feelings)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-charge-verb-2">
    <ns4:gloss xml:lang="en-us">(blame for, make a claim of wrongdoing or misbehavior against; "he charged me director with indifference")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#form_cognitive_behavior_therapy_cognitive_0">
    <rdf:type rdf:resource="http://www.w3.org/ns/lemon/ontolex#Form"/>
    <ontolex:writtenRep>cognitive</ontolex:writtenRep>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_severity_control_level_asperity_5">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Severity_Control_Level"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000783">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-string-noun-4">
    <ns4:gloss xml:lang="en-us">(a sequentially ordered set of things or events or ideas in which each successive member is related to the preceding; "a string of islands"; "train of mourners"; "a train of thought")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-amastia-noun-1">
    <ns4:gloss xml:lang="en-us">(absence of the mammary glands (either through surgery or developmental defect))</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-correction-noun-5">
    <ns4:gloss xml:lang="en-us">(a drop in stock market activity or stock prices following a period of increases; "market runups are invariably followed by a correction")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-film_editing-noun-1">
    <ns4:gloss xml:lang="en-us">(the activity of selecting the scenes to be shown and putting them together to create a film)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#form_severity_control_level_hardship_0">
    <ontolex:writtenRep>hardship</ontolex:writtenRep>
    <rdf:type rdf:resource="http://www.w3.org/ns/lemon/ontolex#Form"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-emotional_arousal-noun-1">
    <ns4:gloss xml:lang="en-us">(the arousal of strong emotions and emotional behavior)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0020005">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#form_intrusive_thoughts_recurring_thoughts_3">
    <rdf:type rdf:resource="http://www.w3.org/ns/lemon/ontolex#Form"/>
    <ontolex:writtenRep>recurring thoughts</ontolex:writtenRep>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_objects_physical_objects_3">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Objects"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-molecular_biology-noun-1">
    <ns4:gloss xml:lang="en-us">(the branch of biology that studies the structure and activity of macromolecules essential to life (and especially with their genetic role))</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-conveyer_belt-noun-1">
    <ns4:gloss xml:lang="en-us">(a moving belt that transports objects (as in a factory))</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-initiate-noun-3">
    <ns4:gloss xml:lang="en-us">(people who have been introduced to the mysteries of some field or activity; "it is very familiar to the initiate")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-aggravation-noun-2">
    <ns4:gloss xml:lang="en-us">(unfriendly behavior that causes anger or resentment)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-votary-noun-3">
    <ns4:gloss xml:lang="en-us">(a devoted (almost religiously so) adherent of a cause or person or activity; "the cultured votary of science")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-planetary_nebula-noun-1">
    <ns4:gloss xml:lang="en-us">(a nebula that was once thought to be a star with its planets but is now thought to be a very hot star surrounded by an expanding envelope of ionized gases that emit a fluorescent glow because of intense radiation from the star)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-surviving-adjectivesatellite-1">
    <ns4:gloss xml:lang="en-us">(still in existence; "the Wollemi pine found in Australia is a surviving specimen of a conifer thought to have been long extinct and therefore known as a living fossil"; "the only surviving frontier blockhouse in Pennsylvania")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0035180">
    <rdfs:label>larval wandering behavior</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_008749">
    <obo:IAO_0000115 xml:lang="en">A transgender woman's final act of penile masturbation before genital gender confirmation surgery.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000460">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
