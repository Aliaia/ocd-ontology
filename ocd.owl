  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-Taliban-noun-1">
    <ns4:gloss xml:lang="en-us">(a fundamentalist Islamic militia; in 1995 the Taliban militia took over Afghanistan and in 1996 took Kabul and set up an Islamic government; "the Taliban enforced a strict Muslim code of behavior")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#propertyform_hastrigger_caused_by_trigger_6">
