    <schema:alternateName xml:lang="en">self-destructive behaviors</schema:alternateName>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0048150">
    <obo:IAO_0000115>Any process that results in a change in the behavior of an organism as a result of an ether stimulus.</obo:IAO_0000115>
    <rdfs:label>behavioral response to ether</rdfs:label>
  </rdf:Description>
