  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-privately-adverb-1">
    <ns4:gloss xml:lang="en-us">(kept private or confined to those intimately concerned; "it was discussed privately between the two men"; "privately, she thought differently"; "some member of his own party hoped privately for his defeat"; "he was questioned in private")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-service_industry-noun-1">
    <ns4:gloss xml:lang="en-us">(an industry that provides services rather than tangible objects)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-think-verb-12">
    <ns4:gloss xml:lang="en-us">(be capable of conscious thought; "Man is the only creature that thinks")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-mutinous-adjectivesatellite-2">
