  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-unenforceable-adjective-1">
    <ns4:gloss xml:lang="en-us">(not enforceable; not capable of being brought about by compulsion; "an unenforceable law"; "unenforceable reforms")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-focal_infection-noun-1">
