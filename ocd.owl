  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-thoracic_medicine-noun-1">
    <ns4:gloss xml:lang="en-us">(the branch of medicine that deals with the diagnosis and treatment of diseases of the chest)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-offhand-adjectivesatellite-2">
    <ns4:gloss xml:lang="en-us">(casually thoughtless or inconsiderate; "an offhand manner"; "she treated most men with offhand contempt")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-drain-noun-2">
    <ns4:gloss xml:lang="en-us">(tube inserted into a body cavity (as during surgery) to remove unwanted material)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-detoxification-noun-1">
