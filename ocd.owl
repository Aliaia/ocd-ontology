  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-hot-adjectivesatellite-22">
    <ns4:gloss xml:lang="en-us">(marked by excited activity; "a hot week on the stock market")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-imperativeness-noun-2">
    <ns4:gloss xml:lang="en-us">(urgently demanding attention; "the insistence of their hunger"; "he pressed his demand with considerable instancy")</ns4:gloss>
    <ns4:hyponymOf rdf:resource="http://www.w3.org/2006/03/wn/wn20/instances/synset-urgency-noun-2"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/MFOEM_000014">
    <obo:IAO_0000115>A negative emotion that is a strong form of anger.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-ideal-adjectivesatellite-2">
    <ns4:gloss xml:lang="en-us">(constituting or existing only in the form of an idea or mental image or conception; "a poem or essay may be typical of its period in idea or ideal content")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-incubation_period-noun-1">
    <ns4:gloss xml:lang="en-us">(the period between infection and the appearance of symptoms of the disease)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-permissible-adjective-1">
    <ns4:gloss xml:lang="en-us">(that may be permitted especially as according to rule; "permissible behavior in school"; "a permissible tax deduction")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-Old_Prussian-noun-1">
    <ns4:gloss xml:lang="en-us">(a dead language of the (non-German) Prussians (extinct after 1700); thought to belong to the Baltic branch of Indo-European)</ns4:gloss>
  </rdf:Description>
