  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_001875">
    <ns3:hasDbXref rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Compulsive_behavior</ns3:hasDbXref>
    <obo:IAO_0000115 xml:lang="en">The behavior of performing an act persistently and repetitively without it leading to reward or pleasure. The act is usually a small, circumscribed behavior, almost ritualistic, yet not pathologically disturbing. Examples of compulsive behavior include twirling of hair, checking something constantly, not wanting pennies in change, straightening tilted pictures, etc.</obo:IAO_0000115>
    <ns3:hasRelatedSynonym xml:lang="en">abnormal compulsive behavior</ns3:hasRelatedSynonym>
    <rdfs:label xml:lang="en">compulsive behavior</rdfs:label>
    <schema:alternateName xml:lang="en">compulsive behaviors</schema:alternateName>
  </rdf:Description>
