    <ontolex:reference rdf:resource="https://w3id.org/ocd#Normal_Routine_Impairment"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-mimicry-noun-2">
    <ns4:gloss xml:lang="en-us">(the resemblance of an animal species to another species or to natural objects; provides concealment and protection from predators)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-wax_paper-noun-1">
