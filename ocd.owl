  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OGMS_0000117">
    <obo:IAO_0000115>A disease stage characterized by the lack of symptoms associated with a given disease</obo:IAO_0000115>
  </rdf:Description>
