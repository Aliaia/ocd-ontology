    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-nearsighted-adjective-1">
    <ns4:gloss xml:lang="en-us">(unable to see distant objects clearly)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-golden_age-noun-1">
    <ns4:gloss xml:lang="en-us">(a time period when some activity or skill was at its peak; "it was the golden age of cinema")</ns4:gloss>
