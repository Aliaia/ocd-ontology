  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_009837">
    <obo:IAO_0000115 xml:lang="en">A mostly historical term used to refer to homosexual sexual activity in which at least one participant does not identify as gay, but who supposedly engages in such behavior due to an absence of heterosexual partners. For instance, in prisons, boarding schools, military bases, ships at sea, convents and monasteries, etc. This conceptualization often oversimplifies matters, ignoring situations which are nonconsensual, those in which comfortable experimentation may take place, and those in which admitting that one identifies as non-heterosexual might be dangerous. Therefore, it has fallen out of use.</obo:IAO_0000115>
    <ns3:hasRelatedSynonym xml:lang="en">behavioral bisexuality</ns3:hasRelatedSynonym>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-time_machine-noun-1">
    <ns4:gloss xml:lang="en-us">(a science fiction machine that is supposed to transport people or objects into the past or the future)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_004504">
    <obo:IAO_0000115 xml:lang="en">An explicit racial derogation; verbal/nonverbal; e.g. name-calling, avoidant behavior, purposeful discriminatory actions.</obo:IAO_0000115>
  </rdf:Description>
