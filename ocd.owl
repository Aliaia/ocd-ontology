    <ns4:containsWordSense rdf:resource="http://www.w3.org/2006/03/wn/wn20/instances/wordsense-accident_surgery-noun-1"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-goad-verb-3">
