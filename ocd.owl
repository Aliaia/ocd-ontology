  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-hyperopic-adjectivesatellite-1">
    <ns4:gloss xml:lang="en-us">(abnormal ability to focus of distant objects)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-property-noun-5">
    <ns4:gloss xml:lang="en-us">(any movable articles or objects used on the set of a play or movie; "before every scene he ran down his checklist of props")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000837">
    <obo:IAO_0000115 xml:lang="en">Fear is a negative emotion induced by a perceived threat that induces one to hide or move quickly away from the location of the perceived threat.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-flare-noun-5">
    <ns4:gloss xml:lang="en-us">(a sudden recurrence or worsening of symptoms; "a colitis flare"; "infection can cause a lupus flare")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#propertylexicalentry_hastreatment_treated_with_0">
