    <ns4:gloss xml:lang="en-us">(to cause a sharp emotional pain; "The thought of her unhappiness pricked his conscience")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-reinforce-verb-2">
    <ns4:gloss xml:lang="en-us">(strengthen and support with rewards; "Let's reinforce good behavior")</ns4:gloss>
