  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-scrub-verb-2">
    <ns4:gloss xml:lang="en-us">(wash thoroughly; "surgeons must scrub prior to an operation")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000327">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
