    <ns4:lexicalForm xml:lang="en-us">orthodontic treatment</ns4:lexicalForm>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-background-noun-2">
    <ns4:gloss xml:lang="en-us">(the part of a scene (or picture) that lies behind objects in the foreground; "he posed her against a background of rolling hills")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#form_obsession_recurrent_idea_4">
