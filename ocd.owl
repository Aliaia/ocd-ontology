  <rdf:Description rdf:about="https://w3id.org/ocd#Hoarding_Disorder">
    <rdfs:comment>Hoarding Disorder is classified under the category of Obsessive-Compulsive and Related Disorders. Hoarding Disorder is characterized by the persistent difficulty discarding or parting with possessions, regardless of their actual value</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/ocd#Obsessive_Compulsive_Related_Disorder"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
