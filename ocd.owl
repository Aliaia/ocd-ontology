  <rdf:Description rdf:about="https://www.ncbi.nlm.nih.gov/protein/NP_004950">
    <obo:IAO_0000115 xml:lang="en">A transcription factor involved in sex determination by controlling activity of genes related to the reproductive glands or gonads and adrenal glands. This protein is encoded by the NR5A1 gene, a member of the nuclear receptor subfamily, located on the long arm of chromosome 9 at position 33.3.</obo:IAO_0000115>
  </rdf:Description>
