  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-sleeping_sickness-noun-1">
    <ns4:gloss xml:lang="en-us">(an encephalitis that was epidemic between 1915 and 1926; symptoms include paralysis of the extrinsic eye muscle and extreme muscular weakness)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_008438">
    <obo:IAO_0000115 xml:lang="en">A dated and rare (and potentially offensive) term referring to the state of being a transfeminine individual, or trans woman, who has not had gender confirmation surgery (specifically, feminizing genitoplasty).</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-impel-verb-1">
    <ns4:gloss xml:lang="en-us">(urge or force (a person) to an action; constrain or motivate)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-neoconservativism-noun-1">
    <ns4:gloss xml:lang="en-us">(an approach to politics or theology that represents a return to a traditional point of view (in contrast to more liberal or radical schools of thought of the 1960s))</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000226">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000106">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-hydroxychloroquine-noun-1">
    <ns4:gloss xml:lang="en-us">(anti-inflammatory drug (trade name Plaquenil) used in the treatment of rheumatoid arthritis and malaria and lupus erythematosus)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000041">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-interface-noun-1">
    <ns4:gloss xml:lang="en-us">((chemistry) a surface forming a common boundary between two things (two objects or liquids or chemical phases))</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-dead-adjectivesatellite-20">
    <ns4:gloss xml:lang="en-us">(lacking animation or excitement or activity; "the party being dead we left early"; "it was a lifeless party until she arrived")</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-methylphenidate-noun-1">
    <ns4:gloss xml:lang="en-us">(central nervous system stimulant (trade name Ritalin) used in the treatment of narcolepsy in adults and attention deficit disorder in children)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000255">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_genetic_factor_transmitted_7">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Genetic_Factor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-rheumatology-noun-1">
    <ns4:gloss xml:lang="en-us">(the branch of medicine dealing with the study and treatment of pathologies of the muscles or tendons or joints)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-beatnik-noun-1">
    <ns4:gloss xml:lang="en-us">(a member of the beat generation; a nonconformist in dress and behavior)</ns4:gloss>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/SYMP_0000267">
    <ns3:hasOBONamespace>symptoms</ns3:hasOBONamespace>
