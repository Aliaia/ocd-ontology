  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GSSO_001364">
    <obo:IAO_0000115 xml:lang="en">Terms originally utilized predominantly within lesbian culture to ascribe or acknowledge a masculine (butch) or feminine (femme) identity with its associated traits, behaviors, styles, self-perception, and so on. However, butch and femme are often utilized in similar senses by LGBTQIA+ persons other than lesbians.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ocd/lexicon#lexicalsense_negative_emotion_distressing_emotions_0">
    <ontolex:reference rdf:resource="https://w3id.org/ocd#Negative_Emotion"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2006/03/wn/wn20/instances/synset-touch-verb-2">
    <ns4:gloss xml:lang="en-us">(perceive via the tactile sense; "Helen Keller felt the physical world by touching people and objects around her")</ns4:gloss>
  </rdf:Description>
