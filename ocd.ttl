obo:GO_0071625 rdfs:label "vocalization behavior",
        "vocalization behavior"@en ;
    obo:IAO_0000115 "The behavior in which an organism produces sounds by a mechanism involving its respiratory system.",
        "The behavior in which an organism produces sounds by a mechanism involving its respiratory system."@en ;
