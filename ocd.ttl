<https://w3id.org/ocd#hasAssociation> a owl:ObjectProperty ;
    rdfs:comment "`hasAssociation' is an object property that links instances of \"behavior,\" \"activity,\" \"intrusive thoughts,\" or \"intrusive urges\" with instances of \"emotions\" and \"impairment\" to represent the relationship between these concepts." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <https://w3id.org/ocd#Activity> <https://w3id.org/ocd#Behavior> <https://w3id.org/ocd#Intrusive_Thoughts> <https://w3id.org/ocd#Intrusive_Urge> ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( <https://w3id.org/ocd#Functional_Impairment> <https://w3id.org/ocd#Negative_Emotion> ) ] .

obo:GSSO_001875 rdfs:label "compulsive behavior"@en ;
    obo:IAO_0000115 "The behavior of performing an act persistently and repetitively without it leading to reward or pleasure. The act is usually a small, circumscribed behavior, almost ritualistic, yet not pathologically disturbing. Examples of compulsive behavior include twirling of hair, checking something constantly, not wanting pennies in change, straightening tilted pictures, etc."@en ;
    ns3:hasDbXref "https://en.wikipedia.org/wiki/Compulsive_behavior"^^xsd:anyURI ;
    ns3:hasRelatedSynonym "abnormal compulsive behavior"@en ;
        
