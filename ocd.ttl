obo:SYMP_0019182 rdfs:label "behavioral symptom"@en ;
    obo:IAO_0000115 "A nervous system symptom that is characterized by an involvement, or relation to, or emphasizes behavior." ;
    ns3:hasOBONamespace "symptoms" .

obo:SYMP_0019183 rdfs:label "hyperactivity"@en ;
    obo:IAO_0000115 "A behavioral symptom that is characterized by an increase in movement, impulsive actions, a shorter attention span, and being easily distracted." ;
    ns3:hasOBONamespace "symptoms" .

obo:SYMP_0019184 obo:IAO_0000115 "A behavioral symptom that is characterized by a restricted rate of information processing by the brain." ;
    ns3:hasOBONamespace "symptoms" .

obo:SYMP_0019185 obo:IAO_0000115 "A behavioral symptom that is characterized by speech, language and communication needs or communication disabilities." ;
    ns3:hasOBONamespace "symptoms" .

obo:SYMP_0019186 obo:IAO_0000115 "A behavioral symptom that is characterized by obsessive and highly-focused interests." ;
    ns3:hasOBONamespace "symptoms" .

obo:SYMP_0019187 rdfs:label "repetitive behavior"@en ;
    obo:IAO_0000115 "A behavioral symptom that is characterized by an unusual repetitive motor movements or manipulation of objects." ;
    ns3:hasOBONamespace "symptoms" .

